#!/bin/sh
# Pre-commit hook for clawdoc.
# To install into git: cp .husky/pre-commit $(git rev-parse --git-dir)/hooks/pre-commit && chmod +x $(git rev-parse --git-dir)/hooks/pre-commit

echo "🔍 Running clawdoc pre-commit checks..."

if ! make test; then
  echo "❌ Detection tests failed. Fix before committing."
  exit 1
fi

if ! make lint 2>/dev/null; then
  echo "❌ Shellcheck failed. Fix before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed"
